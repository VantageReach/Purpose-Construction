---
const navLinks = [
  { label: 'Home', href: '/' },
  {
    label: 'Construction Services',
    href: '/new-construction-lufkin-tx',
    id: 'construction-dropdown',
    children: [
      { label: 'New Construction', href: '/new-construction-lufkin-tx' },
      { label: 'Metal Structures', href: '/metal-structures-lufkin-tx' },
      { label: 'Outdoor Living', href: '/outdoor-living-lufkin-tx' },
      { label: 'Exterior Services', href: '/exterior-services-lufkin-tx' },
    ],
  },
  {
    label: 'Remodeling',
    href: '/remodeling-contractor-lufkin-tx',
    id: 'remodeling-dropdown',
    children: [
      { label: 'Kitchen Remodeling', href: '/kitchen-remodeling-lufkin-tx' },
      { label: 'Bathroom Remodeling', href: '/bathroom-remodeling-lufkin-tx' },
      { label: 'Home Additions', href: '/home-additions-lufkin-tx' },
      { label: 'Interior Painting', href: '/interior-painting-lufkin-tx' },
      { label: 'Flooring Installation', href: '/flooring-installation-lufkin-tx' },
      { label: 'Drywall Services', href: '/drywall-installation-lufkin-tx' },
    ],
  },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white shadow-[0_1px_0_0_#E5DDD5]">
  <!-- Top bar -->
  <div class="bg-charcoal-900 text-white">
    <div class="container-wide flex items-center justify-between px-4 py-2 sm:px-6 lg:px-8 text-xs">
      <span class="hidden sm:block text-charcoal-300 tracking-wide">Serving Lufkin &amp; East Texas</span>
      <a
        href="tel:9365555555"
        class="flex items-center gap-1.5 font-semibold text-white hover:text-brand-red-mid transition-colors duration-150"
      >
        <svg class="h-3.5 w-3.5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        (936) 555-5555
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <div class="container-wide px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 group" aria-label="Purpose Roofing & Construction — Home">
        <img
          src="/images/purpose-roofing-construction-logo.png"
          alt="Purpose Roofing & Construction"
          class="h-14 w-auto transition-opacity duration-200 group-hover:opacity-85"
          width="280"
          height="56"
          loading="eager"
        />
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-0.5">
        {navLinks.map((link) => (
          link.children ? (
            <div class="relative group">
              <button
                type="button"
                class:list={[
                  'flex items-center gap-1 px-3.5 py-2 text-[11px] font-semibold uppercase tracking-wide transition-colors duration-150 rounded',
                  link.children.some(c => currentPath.startsWith(c.href)) || currentPath === link.href
                    ? 'text-brand-red'
                    : 'text-charcoal-700 hover:text-charcoal-900',
                ]}
                aria-expanded="false"
                aria-controls={link.id}
              >
                {link.label}
                <svg class="h-3 w-3 transition-transform duration-200 group-hover:rotate-180 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div
                id={link.id}
                class="absolute left-0 top-full mt-1 w-56 rounded-lg bg-white shadow-card-hover border border-warm-200 opacity-0 invisible translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0"
              >
                <!-- Category hub link -->
                <div class="border-b border-warm-100 px-4 py-2.5">
                  <a
                    href={link.href}
                    class:list={[
                      'text-[10px] font-bold uppercase tracking-widest transition-colors duration-150',
                      currentPath === link.href ? 'text-brand-red' : 'text-charcoal-400 hover:text-brand-red',
                    ]}
                  >
                    View All {link.label} &rarr;
                  </a>
                </div>
                <ul class="py-1.5">
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'block px-4 py-2 text-sm font-semibold tracking-wide transition-colors duration-150',
                          currentPath === child.href
                            ? 'text-brand-red bg-brand-red-light'
                            : 'text-charcoal-700 hover:text-charcoal-900 hover:bg-warm-100',
                        ]}
                        aria-current={currentPath === child.href ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'px-3.5 py-2 text-[11px] font-semibold uppercase tracking-wide transition-colors duration-150 rounded',
                currentPath === link.href
                  ? 'text-brand-red'
                  : 'text-charcoal-700 hover:text-charcoal-900',
              ]}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- Desktop CTA: Call Now -->
      <a
        href="tel:9365555555"
        class="btn-primary hidden lg:inline-flex text-xs py-2.5 px-5 flex-shrink-0"
      >
        <svg class="h-3.5 w-3.5 flex-shrink-0" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        Call Now
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="lg:hidden flex items-center justify-center h-10 w-10 rounded text-charcoal-700 hover:text-charcoal-900 hover:bg-warm-100 transition-colors duration-150"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
      >
        <svg id="menu-icon-open" class="h-5 w-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-close" class="h-5 w-5 hidden" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-warm-200 bg-white"
  >
    <nav aria-label="Mobile navigation" class="container-wide px-4 py-4 sm:px-6 space-y-1">
      {navLinks.map((link) => (
        link.children ? (
          <div>
            <a
              href={link.href}
              class="block px-4 py-2 text-xs font-bold uppercase tracking-widest text-charcoal-500"
            >
              {link.label}
            </a>
            <div class="pl-4 space-y-0.5">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block px-4 py-2 text-sm font-semibold tracking-wide rounded transition-colors duration-150',
                    currentPath === child.href
                      ? 'text-brand-red bg-brand-red-light'
                      : 'text-charcoal-700 hover:bg-warm-100',
                  ]}
                  aria-current={currentPath === child.href ? 'page' : undefined}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'block px-4 py-2 text-sm font-semibold uppercase tracking-widest rounded transition-colors duration-150',
              currentPath === link.href
                ? 'text-brand-red bg-brand-red-light'
                : 'text-charcoal-700 hover:bg-warm-100',
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        )
      ))}
      <div class="pt-2 pb-1 flex flex-col gap-2">
        <a href="tel:9365555555" class="btn-primary w-full justify-center text-xs">
          <svg class="h-3.5 w-3.5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          Call Now · (936) 555-5555
        </a>
        <a href="/contact" class="btn-outline w-full justify-center text-xs">
          Get a Free Quote
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
  });
</script>
