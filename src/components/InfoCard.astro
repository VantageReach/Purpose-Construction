---
interface Props {
  label: string;
  value: string;
  detail?: string;
  icon?: string; // SVG path data
}

const { label, value, detail, icon } = Astro.props;
---

<div class="flex flex-col items-center rounded-lg border border-warm-200 bg-white p-6 text-center shadow-card">
  {icon && (
    <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-md bg-brand-red-light text-brand-red">
      <svg class="h-5 w-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    </div>
  )}
  <p class="text-xs font-semibold uppercase tracking-widest text-charcoal-400">{label}</p>
  <p class="mt-1 font-display text-2xl font-bold leading-none text-charcoal-900">{value}</p>
  {detail && <p class="mt-1 text-xs text-charcoal-400">{detail}</p>}
</div>
