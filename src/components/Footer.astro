---
const serviceLinks = [
  { label: 'Remodeling', href: '/remodeling-contractor' },
  { label: 'Kitchen Remodeling', href: '/kitchen-remodeling' },
  { label: 'Bathroom Remodeling', href: '/bathroom-remodeling' },
  { label: 'Home Additions', href: '/home-additions' },
  { label: 'New Construction', href: '/new-construction' },
  { label: 'Barndominium Construction', href: '/barndominium-construction' },
  { label: 'Outdoor Living', href: '/outdoor-living' },
  { label: 'Exterior Services', href: '/exterior-services' },
];

const companyLinks = [
  { label: 'About Us', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Contact', href: '/contact' },
  { label: 'Free Quote', href: '/contact' },
];

const serviceAreas = [
  { label: 'Lufkin, TX', href: '/contact' },
  { label: 'Burke, TX', href: '/locations/burke' },
  { label: 'Chireno, TX', href: '/locations/chireno' },
  { label: 'Corrigan, TX', href: '/locations/corrigan' },
  { label: 'Diboll, TX', href: '/locations/diboll' },
  { label: 'Etoile, TX', href: '/locations/etoile' },
  { label: 'Hudson, TX', href: '/locations/hudson' },
  { label: 'Huntington, TX', href: '/locations/huntington' },
  { label: 'Nacogdoches, TX', href: '/locations/nacogdoches' },
  { label: 'Pollok, TX', href: '/locations/pollok' },
  { label: 'Redland, TX', href: '/locations/redland' },
  { label: 'Wells, TX', href: '/locations/wells' },
  { label: 'Zavalla, TX', href: '/locations/zavalla' },
];

const year = new Date().getFullYear();
---

<footer class="bg-charcoal-900 text-white">
  <!-- Main footer body -->
  <div class="container-wide section-padding-sm px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-4">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-5 group" aria-label="Purpose Roofing & Construction — Home">
          <div class="rounded-lg bg-white px-4 py-2.5 transition-opacity duration-200 group-hover:opacity-90 inline-block">
            <img
              src="/images/purpose-roofing-construction-logo.png"
              alt="Purpose Roofing & Construction"
              class="h-10 w-auto"
              width="200"
              height="40"
              loading="lazy"
            />
          </div>
        </a>

        <address class="not-italic text-sm text-charcoal-300 leading-relaxed space-y-1">
          <p class="font-semibold text-white">Purpose Construction</p>
          <p>Lufkin, Texas 75904</p>
          <p>
            <a href="tel:9365555555" class="hover:text-white transition-colors duration-150">(936) 555-5555</a>
          </p>
          <p>
            <a href="mailto:info@purposeconstructionco.com" class="hover:text-white transition-colors duration-150">info@purposeconstructionco.com</a>
          </p>
        </address>

        <!-- Sister company -->
        <div class="mt-6 rounded-lg border border-charcoal-700 bg-charcoal-800 p-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-charcoal-400 mb-1">Sister Company</p>
          <a
            href="https://www.purpose-roofing.com"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm font-semibold text-charcoal-200 hover:text-white transition-colors duration-150"
          >
            <svg class="h-4 w-4 text-brand-red" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Purpose Roofing
            <svg class="h-3 w-3 text-charcoal-400" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
          <p class="text-xs text-charcoal-500 mt-1">Need a new roof? We've got you covered.</p>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-widest text-charcoal-400 mb-4">Services</h3>
        <nav aria-label="Footer services navigation">
          <ul class="space-y-2">
            {serviceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-charcoal-300 hover:text-white transition-colors duration-150"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-widest text-charcoal-400 mb-4">Company</h3>
        <nav aria-label="Footer navigation">
          <ul class="space-y-2">
            {companyLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-charcoal-300 hover:text-white transition-colors duration-150"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="mt-8">
          <h3 class="font-display text-sm font-bold uppercase tracking-widest text-charcoal-400 mb-3">Hours</h3>
          <div class="text-sm text-charcoal-300 space-y-1">
            <div class="flex justify-between gap-4">
              <span>Mon – Fri</span>
              <span class="text-white">7:00 AM – 6:00 PM</span>
            </div>
            <div class="flex justify-between gap-4">
              <span>Saturday</span>
              <span class="text-white">8:00 AM – 2:00 PM</span>
            </div>
            <div class="flex justify-between gap-4">
              <span>Sunday</span>
              <span class="text-charcoal-500">Closed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Service areas column -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-widest text-charcoal-400 mb-4">Service Areas</h3>
        <ul class="space-y-1.5">
          {serviceAreas.map((area) => (
            <li class="flex items-center gap-2 text-sm">
              <span class="h-1 w-1 rounded-full bg-brand-red flex-shrink-0" aria-hidden="true"></span>
              <a href={area.href} class="text-charcoal-300 hover:text-white transition-colors duration-150">{area.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-charcoal-800">
    <div class="container-wide flex flex-col items-center justify-between gap-3 px-4 py-5 text-xs text-charcoal-500 sm:flex-row sm:px-6 lg:px-8">
      <p>&copy; {year} Purpose Construction. All rights reserved.</p>
      <p>Insured General Contractor — Lufkin, Texas</p>
    </div>
  </div>
</footer>
