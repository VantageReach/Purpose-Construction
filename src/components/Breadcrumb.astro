---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const allItems = [{ label: 'Home', href: '/' }, ...items];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: allItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: `https://www.purposeconstructionco.com${item.href}`,
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<nav aria-label="Breadcrumb" class="border-b border-warm-200 bg-warm-50">
  <div class="container-wide px-4 py-3 sm:px-6 lg:px-8">
    <ol class="flex flex-wrap items-center gap-1 text-xs font-semibold uppercase tracking-widest">
      {allItems.map((item, index) => (
        <li class="flex items-center gap-1">
          {index > 0 && (
            <svg class="h-3 w-3 text-charcoal-300" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          )}
          {index === allItems.length - 1 ? (
            <span class="text-charcoal-500" aria-current="page">{item.label}</span>
          ) : (
            <a href={item.href} class="text-charcoal-500 hover:text-brand-red transition-colors duration-150">
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
