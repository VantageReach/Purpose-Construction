---
interface Props {
  title: string;
  subtitle?: string;
  tag?: string;
  image?: string;
}

const { title, subtitle, tag, image } = Astro.props;
---

<section class="relative overflow-hidden bg-charcoal-900 py-20 lg:py-28">
  <!-- Background image (when provided) -->
  {image && (
    <img
      src={image}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover opacity-50"
      loading="eager"
      decoding="sync"
    />
  )}
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-charcoal-900/85 via-charcoal-900/60 to-charcoal-900/45" aria-hidden="true"></div>
  <!-- Decorative grid pattern -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
    <svg width="100%" height="100%">
      <defs>
        <pattern id="page-grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#page-grid)"/>
    </svg>
  </div>
  <!-- Red accent bottom border -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-brand-red" aria-hidden="true"></div>
  <!-- Red glow orb -->
  <div class="absolute -top-24 -right-24 h-64 w-64 rounded-full bg-brand-red/10 blur-3xl" aria-hidden="true"></div>

  <div class="container-wide relative z-10 px-4 sm:px-6 lg:px-8">
    {tag && (
      <div class="mb-4">
        <span class="tag-dark">{tag}</span>
      </div>
    )}
    <h1 class="display-lg text-white text-balance max-w-3xl drop-shadow-[0_2px_8px_rgba(0,0,0,0.9)]">{title}</h1>
    {subtitle && (
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/85 drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]">{subtitle}</p>
    )}
  </div>
</section>
