---
interface Props {
  title: string;
  subtitle?: string;
  tag?: string;
  align?: 'center' | 'left';
  theme?: 'light' | 'dark';
}

const { title, subtitle, tag, align = 'left', theme = 'light' } = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : '';
const titleColor = theme === 'dark' ? 'text-white drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]' : 'text-charcoal-900';
const subtitleColor = theme === 'dark' ? 'text-white/80 drop-shadow-[0_1px_2px_rgba(0,0,0,0.7)]' : 'text-charcoal-500';
---

<div class={`mb-10 max-w-2xl ${alignClass}`}>
  {tag && <span class="tag mb-3 inline-block">{tag}</span>}
  <h2 class={`display-md text-balance ${titleColor}`}>{title}</h2>
  {subtitle && (
    <p class={`mt-3 text-base leading-relaxed ${subtitleColor}`}>{subtitle}</p>
  )}
</div>
