---
interface Props {
  title: string;
  subtitle?: string;
  tag?: string;
  align?: 'center' | 'left';
}

const { title, subtitle, tag, align = 'left' } = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : '';
---

<div class={`mb-10 max-w-2xl ${alignClass}`}>
  {tag && <span class="tag mb-3 inline-block">{tag}</span>}
  <h2 class={`display-md text-charcoal-900 text-balance ${align === 'center' ? '' : ''}`}>{title}</h2>
  {subtitle && (
    <p class="mt-3 text-base leading-relaxed text-charcoal-500">{subtitle}</p>
  )}
</div>
