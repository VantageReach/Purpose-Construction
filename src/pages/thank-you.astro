---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You | Purpose Construction"
  description="Thanks for reaching out to Purpose Construction. We'll be in touch within one business day."
>
  <section class="relative flex min-h-screen items-center justify-center overflow-hidden bg-charcoal-900 px-4">
    <!-- Background grid -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]" aria-hidden="true">
      <svg width="100%" height="100%">
        <defs>
          <pattern id="ty-grid" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#ty-grid)"/>
      </svg>
    </div>
    <!-- Red glow -->
    <div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-brand-red/10 blur-3xl pointer-events-none"></div>

    <div class="relative z-10 mx-auto max-w-lg text-center">
      <!-- Check icon -->
      <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full border-2 border-brand-red/60 bg-white">
        <svg class="h-10 w-10 text-brand-red" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <!-- Heading -->
      <span class="mb-4 inline-block text-xs font-bold uppercase tracking-widest text-brand-red">Message Received</span>
      <h1 class="display-lg mb-4 text-white">Thank You for<br>Reaching Out.</h1>
      <p class="mx-auto mb-10 max-w-md text-base leading-relaxed text-charcoal-300">
        We received your request and will be in touch within <strong class="text-white">one business day</strong> to schedule your free on-site consultation. In the meantime, feel free to call us directly.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/" class="btn-primary px-8 py-4">Back to Homepage</a>
        <a
          href="tel:9362552235"
          class="inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/10 px-8 py-4 text-sm font-bold text-white backdrop-blur-sm transition-all duration-200 hover:bg-white/20 hover:border-white/50"
        >
          <svg class="h-4 w-4 text-brand-red" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          Call (936) 255-2235
        </a>
      </div>

      <!-- Google Review prompt -->
      <div class="mt-10 rounded-xl border border-charcoal-700 bg-charcoal-800/60 px-6 py-5">
        <p class="mb-1 text-sm font-semibold text-white">Had a great experience with us?</p>
        <p class="mb-4 text-xs text-charcoal-400">A Google review helps East Texas homeowners find a contractor they can trust.</p>
        <a
          href="https://g.page/r/CUKivaolola3EAE/review"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-bold text-charcoal-900 transition-all duration-200 hover:bg-warm-100"
        >
          <svg class="h-4 w-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          Leave Us a Google Review
        </a>
      </div>

      <!-- Reassurance -->
      <p class="mt-6 text-xs text-charcoal-500">Your information is never shared or sold. &mdash; Purpose Construction, Lufkin TX</p>
    </div>
  </section>
</BaseLayout>
