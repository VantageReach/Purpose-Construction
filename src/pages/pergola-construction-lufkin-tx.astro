---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Pergola Construction',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'City', name: 'Lufkin', containedIn: { '@type': 'State', name: 'Texas' } },
  description: 'Pergola construction in Lufkin, TX — freestanding and attached pergolas in cedar, pine, and composite with optional louvered tops, lattice, and electrical for East Texas outdoor spaces.',
};
---
<BaseLayout
  title="Pergola Construction Lufkin TX | Purpose Construction"
  description="Pergola construction in Lufkin, TX — freestanding and attached pergolas in cedar, pine, and composite. Louvered options, fan wiring, and custom sizing. Call (936) 555-5555."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Outdoor Living', href: '/outdoor-living-lufkin-tx' }, { label: 'Pergola Construction', href: '/pergola-construction-lufkin-tx' }]} />
  <PageHero title="Pergola Construction in Lufkin, TX" subtitle="Custom pergolas in cedar, pine, and composite — freestanding, attached, louvered, and lattice-top structures that transform your East Texas backyard." tag="Outdoor Living Service" />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Pergola Construction" title="Shade, Structure, and Character for Your Outdoor Space" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>A well-built pergola transforms a plain backyard into a defined outdoor room — adding shade, visual structure, and a place to hang lights, fans, and climbing plants. Purpose Construction builds custom pergolas sized and styled to suit your home's architecture and your family's outdoor lifestyle, using materials that hold up in East Texas heat and humidity.</p>
            <p>We build in cedar, which resists moisture and insects naturally and weathers beautifully in the Piney Woods climate, as well as pressure-treated pine and composite materials for different budget points and maintenance preferences. Louvered pergolas — with adjustable roof panels that open and close — are increasingly popular with East Texas homeowners who want shade control without committing to a fully roofed pavilion structure.</p>
            <p>We wire pergolas for ceiling fans and lighting during construction, so your outdoor space is functional from day one. We also integrate pergolas with new deck builds, existing patios, and pool decks throughout Lufkin and Angelina County.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/outdoor-living-lufkin-tx" class="btn-outline">All Outdoor Living</a>
          </div>
        </div>
        <img src="https://placehold.co/640x480/2a2520/555?text=Pergola+Construction" alt="Pergola construction in Lufkin, TX by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Pergola Construction Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Freestanding Pergolas', 'Attached Pergolas', 'Cedar', 'Pine & Composite', 'Louvered Pergolas', 'Lattice Tops', 'Fan/Light Wiring', 'Custom Sizing'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Complete Your Outdoor Space" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Pavilion Construction', href: '/pavilion-construction-lufkin-tx' }, { label: 'Patio Construction', href: '/patio-construction-lufkin-tx' }, { label: 'Deck Construction', href: '/deck-construction-lufkin-tx' }, { label: 'Outdoor Living', href: '/outdoor-living-lufkin-tx' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Let's Design Your Pergola</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free pergola estimate. We build custom outdoor structures across Lufkin and East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
