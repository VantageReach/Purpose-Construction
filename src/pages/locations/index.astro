---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const locations = [
  { city: 'Lufkin', slug: null, county: 'Angelina County', keyword: 'Home Base', desc: 'Our primary service area and home base. We serve all of Lufkin and Angelina County.', href: '/contact' },
  { city: 'Hudson', slug: 'hudson', county: 'Angelina County', keyword: 'General Contractor', desc: 'Just north of Lufkin on US-59 — rapid response, no travel fees.', href: '/locations/hudson' },
  { city: 'Huntington', slug: 'huntington', county: 'Angelina County', keyword: 'Construction Company', desc: 'Full builds and remodels throughout Huntington and surrounding communities.', href: '/locations/huntington' },
  { city: 'Diboll', slug: 'diboll', county: 'Angelina County', keyword: 'Remodeling Contractor', desc: 'Kitchen, bath, additions, and new construction for Diboll homeowners.', href: '/locations/diboll' },
  { city: 'Nacogdoches', slug: 'nacogdoches', county: 'Nacogdoches County', keyword: 'Renovation Services', desc: 'Serving Nacogdoches and Nacogdoches County — remodeling to new builds.', href: '/locations/nacogdoches' },
  { city: 'Corrigan', slug: 'corrigan', county: 'Polk County', keyword: 'Home Remodeling', desc: 'South into Polk County — same crew, same standards, no travel charges.', href: '/locations/corrigan' },
  { city: 'Wells', slug: 'wells', county: 'Cherokee County', keyword: 'Home Builder', desc: 'Custom homes and barndominiums on Cherokee County rural land.', href: '/locations/wells' },
  { city: 'Zavalla', slug: 'zavalla', county: 'Angelina County', keyword: 'Construction Services', desc: 'East Angelina County — metal structures, barndominiums, and remodeling.', href: '/locations/zavalla' },
  { city: 'Pollok', slug: 'pollok', county: 'Angelina County', keyword: 'Home Renovation', desc: 'Northwest Angelina County — outdoor living, renovations, rural builds.', href: '/locations/pollok' },
  { city: 'Redland', slug: 'redland', county: 'Angelina County', keyword: 'Remodeling Services', desc: 'Right next door to Lufkin — fast scheduling, full remodeling services.', href: '/locations/redland' },
  { city: 'Burke', slug: 'burke', county: 'Angelina County', keyword: 'General Contractor', desc: 'South Angelina County — decks, remodels, additions, and new construction.', href: '/locations/burke' },
  { city: 'Etoile', slug: 'etoile', county: 'Nacogdoches County', keyword: 'Construction Contractor', desc: 'Near Sam Rayburn Reservoir — rural builds, lake-area outdoor living.', href: '/locations/etoile' },
  { city: 'Chireno', slug: 'chireno', county: 'Nacogdoches County', keyword: 'Renovation Contractor', desc: 'Historic Nacogdoches County community — renovation and new construction.', href: '/locations/chireno' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Purpose Construction',
  description: 'Purpose Construction serves all of East Texas — Lufkin, Nacogdoches, Diboll, Huntington, and surrounding communities with residential and commercial construction and remodeling.',
  url: 'https://www.purposeconstructionco.com/locations',
  telephone: '+19365555555',
  address: { '@type': 'PostalAddress', addressLocality: 'Lufkin', addressRegion: 'TX', postalCode: '75904', addressCountry: 'US' },
  areaServed: { '@type': 'State', name: 'Texas' },
};
---
<BaseLayout
  title="Service Areas | Purpose Construction — East Texas"
  description="Purpose Construction serves Lufkin, Nacogdoches, Diboll, Huntington, Hudson, Corrigan, Wells, Zavalla, Pollok, Redland, Burke, Etoile, and Chireno. Click your city for local info."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Locations', href: '/locations' }]} />
  <PageHero
    title="East Texas Construction & Remodeling"
    subtitle="Purpose Construction is based in Lufkin and serves homeowners and businesses throughout East Texas — from Nacogdoches County to Polk County and everywhere in between."
    tag="Service Areas"
    image="/images/remodeling-contractor-east-texas.jpg"
  />

  <!-- Intro -->
  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Where We Work" title="Locally Based, Regionally Trusted" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Purpose Construction is based in Lufkin, TX — the center of our service area and the community we call home. From here, we dispatch crews throughout Angelina County, Nacogdoches County, Cherokee County, Polk County, and surrounding areas without travel surcharges or reduced service quality for communities outside the city.</p>
            <p>Every location page below is built around that specific community — local knowledge, driving directions, and content specific to homeowners in that area. Click your city to learn more about how we serve your neighborhood.</p>
            <p>If your city isn't listed, we may still serve your area. Call us or fill out a contact form and we'll let you know within one business day.</p>
          </div>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="tel:9365555555" class="btn-outline">(936) 555-5555</a>
          </div>
        </div>
        <div class="rounded-xl border border-warm-200 bg-white p-6 shadow-card space-y-4">
          <p class="text-xs font-bold uppercase tracking-widest text-charcoal-400">Our Base</p>
          <div>
            <p class="text-lg font-bold text-charcoal-900">Purpose Construction</p>
            <p class="text-sm text-charcoal-600">Lufkin, TX 75904</p>
            <a href="tel:9365555555" class="mt-1 block text-sm font-semibold text-brand-red">(936) 555-5555</a>
            <a href="mailto:info@purposeconstructionco.com" class="mt-0.5 block text-sm text-charcoal-500">info@purposeconstructionco.com</a>
          </div>
          <div class="border-t border-warm-200 pt-4 text-xs text-charcoal-500 space-y-1">
            <p>Mon–Fri: 7:00 AM – 6:00 PM</p>
            <p>Saturday: 8:00 AM – 2:00 PM</p>
            <p>Sunday: Closed</p>
          </div>
          <div class="overflow-hidden rounded-lg border border-warm-200">
            <iframe
              src="https://maps.google.com/maps?q=Lufkin,+Texas+75904&output=embed"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Purpose Construction — Lufkin, TX"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Location grid -->
  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading
        tag="All Service Areas"
        title="Choose Your City"
        subtitle="Click any location below for local info, driving directions, community-specific content, and FAQs."
        align="center"
      />
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {locations.map((loc) => (
          <a
            href={loc.href}
            class="group flex flex-col rounded-xl border border-warm-200 bg-white p-6 shadow-card hover:border-brand-red-mid hover:shadow-card-hover transition-all duration-200"
          >
            <div class="mb-4 flex items-start justify-between">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-brand-red mb-1">{loc.county}</p>
                <h2 class="text-xl font-bold text-charcoal-900 group-hover:text-brand-red transition-colors duration-200">{loc.city}, TX</h2>
              </div>
              <span class="rounded-md bg-warm-100 px-2.5 py-1 text-xs font-semibold text-charcoal-500">{loc.keyword}</span>
            </div>
            <p class="text-sm leading-relaxed text-charcoal-600 flex-1">{loc.desc}</p>
            <p class="mt-4 text-xs font-semibold text-brand-red group-hover:gap-2 transition-all duration-200">
              View {loc.city} page →
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Don't See Your City?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">We may still serve your area. Contact Purpose Construction and we'll let you know within one business day whether we can take your project.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Contact Us</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
