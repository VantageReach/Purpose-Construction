---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Walkway Installation',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'City', name: 'Lufkin', containedIn: { '@type': 'State', name: 'Texas' } },
  description: 'Walkway installation in Lufkin, TX — poured concrete, paver, flagstone, and stepping stone walkways with proper base prep and drainage for East Texas homes.',
};
---
<BaseLayout
  title="Walkway Installation Lufkin TX | Purpose Construction"
  description="Walkway installation in Lufkin, TX — concrete, paver, flagstone, and stepping stone paths with proper base prep and edging. Purpose Construction serves East Texas homeowners."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Outdoor Living', href: '/outdoor-living-lufkin-tx' }, { label: 'Walkway Installation', href: '/walkway-installation-lufkin-tx' }]} />
  <PageHero title="Walkway Installation in Lufkin, TX" subtitle="Concrete, paver, flagstone, and stepping stone walkways — properly built with base prep, edging, and drainage to handle East Texas soil and weather." tag="Outdoor Living Service" />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Walkway Installation" title="Paths That Look Good and Stay in Place" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>A well-designed walkway does two things — it moves people safely through a yard or from a driveway to a front door, and it adds character to your home's exterior. Purpose Construction installs walkways in concrete, pavers, natural flagstone, and stepping stones, working with your landscaping and the existing grade to create paths that look intentional and hold up over time.</p>
            <p>In East Texas, walkways without proper base preparation and edging tend to settle unevenly as the clay soils shift with seasonal moisture. We compact subbase material, install edge restraints where needed, and manage drainage so water doesn't pool on or around the path after Lufkin's frequent heavy rains. This is especially important at entries and side-yard paths where standing water would create a constant muddy mess.</p>
            <p>Whether you want a formal concrete front walkway, a casual flagstone garden path, or a paver walkway connecting a back patio to a pool area, we handle the design, layout, and installation from start to finish.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/outdoor-living-lufkin-tx" class="btn-outline">All Outdoor Living</a>
          </div>
        </div>
        <img src="https://placehold.co/640x480/2a2520/555?text=Walkway+Installation" alt="Walkway installation in Lufkin, TX by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Walkway Installation Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Poured Concrete', 'Paver Walkways', 'Flagstone', 'Stepping Stones', 'Base Prep', 'Edging', 'Drainage', 'Lighting Conduit'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Related Outdoor Services" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Patio Construction', href: '/patio-construction-lufkin-tx' }, { label: 'Driveway Installation', href: '/driveway-installation-lufkin-tx' }, { label: 'Outdoor Living', href: '/outdoor-living-lufkin-tx' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Let's Build Your Walkway</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free walkway estimate. We serve Lufkin and all of East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
