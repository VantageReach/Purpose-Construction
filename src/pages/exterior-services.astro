---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Exterior Services Contractor',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Exterior home improvement services across East Texas — siding, windows, doors, exterior painting, gutters, and insulation.',
};

const services = [
  { title: 'Siding Installation', body: 'Fiber cement, vinyl, engineered wood, and LP SmartSide siding installed to protect your home from East Texas weather.', href: '/siding-installation' },
  { title: 'Window Installation', body: 'Energy-efficient replacement windows and new construction windows — installed with proper flashing and sealing.', href: '/window-installation' },
  { title: 'Door Installation', body: 'Exterior entry doors, patio doors, French doors, and storm doors installed securely and sealed for energy efficiency.', href: '/door-installation' },
  { title: 'Exterior Painting', body: 'Professional exterior painting with proper prep, primer, and premium paint that holds up to East Texas sun and humidity.', href: '/exterior-painting' },
  { title: 'Gutter Installation', body: 'Seamless aluminum and steel gutter systems installed with proper slope and drainage to protect your foundation.', href: '/gutter-installation' },
  { title: 'Insulation Installation', body: 'Spray foam, blown-in, and batt insulation for walls, attics, and crawl spaces — reducing energy costs year-round.', href: '/insulation-installation' },
];
---

<BaseLayout
  title="Exterior Services East Texas | Purpose Construction"
  description="Exterior home improvement services across East Texas. Purpose Construction installs siding, windows, doors, gutters, and insulation — and handles exterior painting across East Texas. Free estimates."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Exterior Services', href: '/exterior-services' }]} />
  <PageHero
    title="Exterior Services in East Texas"
    subtitle="Protect and upgrade the outside of your home with Purpose Construction. Siding, windows, doors, painting, gutters, and insulation across East Texas."
    tag="Exterior Home Services"
    image="/images/exterior-services-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading
        tag="Exterior Services"
        title="Your Home's Defense Against the Elements"
        subtitle="East Texas storms, humidity, and UV exposure demand exterior materials and installation that actually hold up. We don't cut corners on the work that protects everything inside."
      />
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((svc) => (
          <a
            href={svc.href}
            class="group relative rounded-xl border border-warm-200 bg-white p-6 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-red-mid"
          >
            <h2 class="display-sm mb-2 text-charcoal-900">{svc.title}</h2>
            <p class="text-sm leading-relaxed text-charcoal-500">{svc.body}</p>
            <span class="service-link mt-4 inline-flex">
              Learn more
              <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sister company roofing mention -->
  <section class="section-padding-sm bg-charcoal-900 border-t border-charcoal-800">
    <div class="container-mid px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-charcoal-700 bg-charcoal-800 p-8 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-charcoal-400 mb-1">Also Need Roofing?</p>
          <h2 class="display-sm text-white mb-2">Purpose Roofing — Our Sister Company</h2>
          <p class="text-sm text-charcoal-300 max-w-md">While Purpose Construction handles siding, windows, and exterior work, roofing is handled by our sister company. Same ownership, same values, same commitment to East Texas homeowners.</p>
        </div>
        <a href="https://www.purpose-roofing.com" target="_blank" rel="noopener noreferrer" class="btn-outline flex-shrink-0 border-charcoal-600 text-charcoal-200 hover:bg-white hover:text-charcoal-900 hover:border-white">
          Visit Purpose Roofing →
        </a>
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Also From Purpose Construction" title="More Services" />
      <div class="flex flex-wrap gap-3">
        {[
          { label: 'Remodeling', href: '/remodeling-contractor' },
          { label: 'New Construction', href: '/new-construction' },
          { label: 'Outdoor Living', href: '/outdoor-living' },
        ].map((link) => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-warm-50 px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">
            {link.label} →
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Protect Your Home's Exterior</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Call or fill out the form for a free exterior assessment and estimate. We'll identify what needs attention and give you a clear, honest scope of work.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
