---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'New Construction Contractor',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://www.purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Custom new construction for residential homes, commercial buildings, barndominiums, pole barns, and tiny homes across East Texas and East Texas.',
};

const services = [
  { title: 'Residential Construction', body: 'Custom single-family homes built to your plans or from scratch — floor plans, materials, and finishes chosen by you.', href: '/residential-construction', core: false },
  { title: 'Commercial Construction', body: 'Commercial shells, tenant buildouts, warehouses, and office construction for businesses across East Texas.', href: '/commercial-construction', core: false },
  { title: 'Barndominium Construction', body: 'The most-requested build in rural East Texas. Custom barndominiums with metal exteriors, open-plan interiors, and full utility hookups.', href: '/barndominium-construction', core: true },
  { title: 'Pole Barn Construction', body: 'Agricultural, storage, and workshop pole barns built to last on your East Texas property.', href: '/pole-barn-construction', core: false },
  { title: 'Tiny Home Construction', body: 'Efficient, custom-built tiny homes — permanent foundation or slab — tailored to your property and lifestyle.', href: '/tiny-home-construction', core: false },
];
---

<BaseLayout
  title="New Construction Contractor East Texas | Purpose Construction"
  description="Purpose Construction builds custom homes, barndominiums, commercial structures, pole barns, and tiny homes across East Texas and East Texas. Insured general contractor. Free estimates."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'New Construction', href: '/new-construction' }]} />
  <PageHero
    title="New Construction in East Texas"
    subtitle="Purpose Construction builds from the ground up — custom homes, barndominiums, commercial structures, and more. Serving East Texas with insured construction."
    tag="New Construction Services"
    image="/images/new-construction-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading
        tag="What We Build"
        title="New Construction Services"
        subtitle="Whether you're breaking ground on a custom home, a barndominium, or a commercial build — we bring expertise, transparency, and East Texas craftsmanship to every project."
      />
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((svc) => (
          <a
            href={svc.href}
            class="group relative rounded-xl border border-warm-200 bg-white p-6 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-red-mid"
          >
            {svc.core && <span class="tag mb-3 inline-block text-[10px]">Featured</span>}
            <h2 class="display-sm mb-2 text-charcoal-900">{svc.title}</h2>
            <p class="text-sm leading-relaxed text-charcoal-500">{svc.body}</p>
            <span class="service-link mt-4 inline-flex">
              Learn more
              <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <img
          src="/images/new-construction-east-texas.jpg"
          alt="New construction project by Purpose Construction in East Texas"
          class="rounded-xl shadow-hero"
          width="640"
          height="480"
          loading="lazy"
          decoding="async"
        />
        <div>
          <SectionHeading tag="Our Approach" title="Built on Your Terms" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>New construction is the most significant investment most families and businesses ever make. We treat it that way — with detailed planning, written contracts, and constant communication throughout the build.</p>
            <p>East Texas land varies significantly. Sandy soils in some areas, heavy clay in others. We know what foundation types work where, what framing holds up to local humidity, and how to build for long-term performance in this region. We build throughout <a href="/locations/nacogdoches" class="text-brand-red hover:underline font-semibold">Nacogdoches</a>, <a href="/locations/huntington" class="text-brand-red hover:underline font-semibold">Huntington</a>, <a href="/locations/wells" class="text-brand-red hover:underline font-semibold">Wells</a>, and across all of Angelina County and Cherokee County.</p>
            <p>From permit pull to final walkthrough, Purpose Construction manages the full scope — so you're not coordinating ten different contractors while trying to run your life. If you're considering a <a href="/barndominium-construction" class="text-brand-red hover:underline font-semibold">barndominium</a> or <a href="/metal-structures" class="text-brand-red hover:underline font-semibold">metal structure</a> instead of a traditional build, we handle those too.</p>
          </div>
          <div class="mt-6">
            <a href="/contact" class="btn-primary">Start Planning Your Build</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-100 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Also From Purpose Construction" title="More Services" />
      <div class="flex flex-wrap gap-3">
        {[
          { label: 'Remodeling', href: '/remodeling-contractor' },
          { label: 'Outdoor Living', href: '/outdoor-living' },
          { label: 'Exterior Services', href: '/exterior-services' },
        ].map((link) => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">
            {link.label} →
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Let's Plan Your Build</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact us for a free consultation. We'll review your site, your plans, and your budget — and put together a proposal that makes sense.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9362552235" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 255-2235</a>
      </div>
    </div>
  </section>
</BaseLayout>
