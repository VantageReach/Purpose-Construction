---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Deck Construction',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://www.purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Deck construction across East Texas — pressure-treated lumber, composite decking, and hardwood decks with proper footings, railings, and stairs for East Texas homes.',
};
---
<BaseLayout
  title="Deck Construction East Texas | Purpose Construction"
  description="Deck construction across East Texas — pressure-treated, composite, and hardwood decks with proper footings, railings, and stairs. Purpose Construction builds across East Texas."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Outdoor Living', href: '/outdoor-living' }, { label: 'Deck Construction', href: '/deck-construction' }]} />
  <PageHero title="Deck Construction in East Texas" subtitle="Custom wood and composite decks built on proper footings with railings, stairs, and detail work — designed to last through East Texas weather." tag="Outdoor Living Service" 
    image="/images/deck-construction-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Deck Construction" title="Decks Built to Handle the East Texas Climate" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>East Texas humidity is hard on wood decks. The wet seasons, high moisture content in the air, and cycles of rain and heat cause untreated or poorly installed decking to warp, rot, and deteriorate within a few years. Purpose Construction builds decks that account for this from the start — using properly graded pressure-treated lumber, composite decking systems, or hardwood species that are proven in humid climates, with the right fasteners and spacing to allow for movement.</p>
            <p>Footings and framing are the foundation of any deck, and we don't cut corners on them. Concrete footings set to proper depth for East Texas soil conditions, beam sizing calculated for the load, and ledger connections that won't pull away from the house — these are the details that separate a deck that lasts 20 years from one that fails in five.</p>
            <p>We build freestanding and attached decks of any size across East Texas and across Angelina County, from simple back-door platforms to large multi-level entertaining decks with integrated pergola structures.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/outdoor-living" class="btn-outline">All Outdoor Living</a>
          </div>
        </div>
        <img src="/images/deck-construction-east-texas.jpg" alt="Deck construction across East Texas by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Deck Construction Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Pressure-Treated Lumber', 'Composite Decking', 'Hardwood', 'Framing & Footings', 'Railings', 'Stairs', 'Fascia', 'Lighting Conduit', 'Pergola Integration'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Complete Your Outdoor Space" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Patio Construction', href: '/patio-construction' }, { label: 'Pergola Construction', href: '/pergola-construction' }, { label: 'Outdoor Living', href: '/outdoor-living' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Ready to Build Your Deck?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free deck estimate. We serve Lufkin and all of East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9362552235" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 255-2235</a>
      </div>
    </div>
  </section>
</BaseLayout>
