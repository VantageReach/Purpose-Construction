---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const faqs = [
  { q: 'What types of home additions does Purpose Construction build?', a: 'We build room additions, sunrooms, bonus rooms, master suite additions, garage conversions, in-law suites, second-story additions, and full rear extensions. If you need more space, we can build it.' },
  { q: 'Do home additions require permits in Lufkin?', a: 'Yes — all structural additions require permits from the City of Lufkin or Angelina County. Purpose Construction pulls all required permits and ensures every addition is built to current building codes.' },
  { q: 'How long does a home addition take?', a: 'Timeline depends heavily on size and complexity. A single-room addition typically takes 6–10 weeks. A full master suite or second-story addition can take 3–5 months. We provide a detailed schedule in the proposal.' },
  { q: 'Will a home addition match my existing house?', a: 'Matching existing siding, roofline, windows, and interior finishes is a priority for our team. We assess your home\'s materials during the consultation phase and select matching or complementary options so the addition looks like it was always part of the house.' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Home Additions',
    provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://www.purposeconstructionco.com' },
    areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
    description: 'Home addition contractor across East Texas. Room additions, master suites, bonus rooms, sunrooms, and second-story additions for East Texas homeowners.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---

<BaseLayout
  title="Home Additions East Texas | Purpose Construction"
  description="Home addition contractor across East Texas. Purpose Construction builds room additions, master suites, bonus rooms, and sunrooms across East Texas. Free estimates — call (936) 555-5555."
  schema={schema}
>
  <Breadcrumb items={[
    { label: 'Services', href: '/services' },
    { label: 'Remodeling', href: '/remodeling-contractor' },
    { label: 'Home Additions', href: '/home-additions' },
  ]} />

  <PageHero
    title="Home Additions in East Texas"
    subtitle="Need more space without moving? Purpose Construction designs and builds home additions across East Texas — from single rooms to full second stories."
    tag="Core Service"
    image="/images/home-additions-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Home Additions" title="Expand Without Relocating" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Moving is expensive and disruptive. A well-designed home addition gives your family the space you need while keeping you in the neighborhood and the home you already love. Purpose Construction builds additions that blend seamlessly with your existing structure — matching rooflines, siding, and interior finishes so nothing looks out of place.</p>
            <p>We handle the full process: architectural planning, permit submission, foundation work, framing, exterior, MEP rough-in, and all interior finishes. You get a single point of contact and a clear written scope before any work starts.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="tel:9365555555" class="btn-outline">Call (936) 555-5555</a>
          </div>
        </div>
        <img
          src="/images/home-additions-east-texas.jpg"
          alt="Home addition project by Purpose Construction in East Texas"
          class="rounded-xl shadow-hero"
          width="640"
          height="480"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Types of Additions" title="What We Build" align="center" />
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: 'Room Additions', body: 'Expand a bedroom, living area, or create a dedicated office or playroom attached to your existing home.' },
          { title: 'Master Suite Additions', body: 'Add a primary bedroom with ensuite bath, walk-in closet, and all the space your family needs.' },
          { title: 'Sunrooms & Enclosed Patios', body: 'Convert existing covered areas or build new three-season and four-season sunrooms.' },
          { title: 'Bonus Rooms', body: 'Above-garage bonus rooms, loft spaces, and flex rooms for families that need versatile square footage.' },
          { title: 'In-Law Suites', body: 'Attached or detached in-law suites with private entrance, bedroom, bath, and kitchenette.' },
          { title: 'Second-Story Additions', body: 'Full second-story additions that double your living space without increasing your footprint.' },
        ].map((item) => (
          <div class="rounded-xl border border-warm-200 bg-warm-50 p-6 shadow-card">
            <h3 class="display-sm mb-2 text-charcoal-900">{item.title}</h3>
            <p class="text-sm leading-relaxed text-charcoal-500">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-mid px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Common Questions" title="Home Addition FAQs" align="center" />
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-warm-200 bg-warm-50 shadow-card">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 list-none">
              <h3 class="text-sm font-semibold text-charcoal-800 pr-4">{faq.q}</h3>
              <svg class="h-5 w-5 flex-shrink-0 text-charcoal-400 transition-transform duration-200 group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-charcoal-600">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Often Paired With Home Additions" />
      <div class="flex flex-wrap gap-3">
        {[
          { label: 'Kitchen Remodeling', href: '/kitchen-remodeling' },
          { label: 'Bathroom Remodeling', href: '/bathroom-remodeling' },
          { label: 'Residential Construction', href: '/residential-construction' },
          { label: 'All Remodeling Services', href: '/remodeling-contractor' },
        ].map((link) => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">
            {link.label} →
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Plan Your Home Addition</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Call or contact us online for a free consultation. We'll assess your home and help you determine the right addition for your family's needs and your property.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
