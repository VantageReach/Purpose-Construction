---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Pavilion Construction',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Pavilion construction across East Texas — fully roofed outdoor structures with concrete slab, ceiling fans, lighting, screened walls, and outdoor kitchen rough-in for East Texas backyards.',
};
---
<BaseLayout
  title="Pavilion Construction East Texas | Purpose Construction"
  description="Pavilion construction across East Texas — fully roofed outdoor structures with fans, lighting, screened walls, and outdoor kitchen rough-in. Purpose Construction builds across East Texas."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Outdoor Living', href: '/outdoor-living' }, { label: 'Pavilion Construction', href: '/pavilion-construction' }]} />
  <PageHero title="Pavilion Construction in East Texas" subtitle="Fully roofed outdoor pavilions with concrete slabs, ceiling fans, lighting, and optional screened walls — built for year-round East Texas outdoor living." tag="Outdoor Living Service" 
    image="/images/pavilion-construction-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Pavilion Construction" title="A True Outdoor Room for East Texas Living" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>An outdoor pavilion is the highest-value outdoor living addition most East Texas homeowners can make. Unlike a pergola, a pavilion has a full roof — which means it's usable year-round, even during Lufkin's afternoon thunderstorms. Purpose Construction designs and builds custom pavilions in cedar and metal roofing combinations that complement your home and hold up in the Piney Woods climate without constant maintenance.</p>
            <p>We pour the concrete slab, frame the structure, install the roofing, wire for ceiling fans and recessed lighting, and rough in for an outdoor kitchen or bar area if you're planning one. Screened wall panels can be added to manage mosquitoes during East Texas spring and fall seasons, turning your pavilion into a genuinely comfortable outdoor room even when bugs are heavy.</p>
            <p>Every pavilion we build is permitted and engineered to local code, with footings designed for the clay soils common around Lufkin and Angelina County. We size each structure to your lot and design it to feel intentional, not like an afterthought bolted onto the back of the house.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/outdoor-living" class="btn-outline">All Outdoor Living</a>
          </div>
        </div>
        <img src="/images/pavilion-construction-east-texas.jpg" alt="Pavilion construction across East Texas by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Pavilion Construction Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Fully Roofed Structure', 'Custom Sizing', 'Ceiling Fans & Lighting', 'Screened Walls', 'Concrete Slab', 'Outdoor Kitchen Rough-In', 'Cedar & Metal Roofing'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Complete Your Outdoor Space" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Pergola Construction', href: '/pergola-construction' }, { label: 'Patio Construction', href: '/patio-construction' }, { label: 'Outdoor Living', href: '/outdoor-living' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Ready for a Pavilion?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free pavilion estimate. We build custom outdoor structures across East Texas and East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
