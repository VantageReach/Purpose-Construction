---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Gutter Installation',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://www.purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Gutter installation across East Texas — seamless aluminum and steel gutters with downspouts, gutter guards, and proper slope for drainage around East Texas homes.',
};
---
<BaseLayout
  title="Gutter Installation East Texas | Purpose Construction"
  description="Gutter installation across East Texas — seamless aluminum gutters, downspouts, gutter guards, and custom colors. Purpose Construction protects East Texas homes from water damage. Call (936) 255-2235."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Exterior Services', href: '/exterior-services' }, { label: 'Gutter Installation', href: '/gutter-installation' }]} />
  <PageHero title="Gutter Installation in East Texas" subtitle="Seamless aluminum and steel gutters installed with proper slope, downspout placement, and gutter guards — protecting East Texas homes from heavy rainfall and foundation water damage." tag="Exterior Service" 
    image="/images/gutter-installation-lufkin-tx.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Gutter Installation" title="Managing East Texas Rainfall Starts at the Roofline" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Lufkin receives some of the highest average rainfall in Texas — routinely seeing heavy downpours that dump inches of water in a short time. Without properly sized and sloped gutters directing that water away from your foundation, you're inviting erosion at the foundation perimeter, water intrusion in crawl spaces and basements, and landscape destruction every time it rains hard. Purpose Construction installs seamless gutters that are sized and configured to handle the high-volume rainfall events common across Angelina County.</p>
            <p>Seamless aluminum gutters are fabricated on-site in one continuous run, eliminating the seams where sectional gutters typically leak and fail over time. We install them with proper slope — enough to drain quickly without being so steep the water rushes past the downspout and over the edge. Downspout placement is calculated to move water away from the foundation perimeter, not just redirect it to a different spot along the house.</p>
            <p>East Texas pine trees drop significant debris — needles, cones, and small branches — that fill gutters quickly. We offer gutter guard systems that keep debris out while allowing water through, reducing maintenance for homeowners surrounded by the Piney Woods landscape.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/exterior-services" class="btn-outline">All Exterior Services</a>
          </div>
        </div>
        <img src="/images/gutter-installation-lufkin-tx.jpg" alt="Gutter installation across East Texas by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Gutter Installation Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Seamless Aluminum Gutters', 'Steel Gutters', 'Downspouts', 'Gutter Guards', 'Fascia Mounting', 'Proper Slope & Drainage', 'Custom Colors'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Related Exterior Services" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Siding Installation', href: '/siding-installation' }, { label: 'Exterior Services', href: '/exterior-services' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Protect Your Home From the Rain</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free gutter installation estimate. We serve Lufkin and all of East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9362552235" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 255-2235</a>
      </div>
    </div>
  </section>
</BaseLayout>
