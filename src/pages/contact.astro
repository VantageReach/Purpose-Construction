---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout
  title="Contact Us | Purpose Construction — Lufkin, TX"
  description="Get a free quote from Purpose Construction in Lufkin, TX. Call (936) 555-5555 or fill out our contact form. We serve Lufkin, Nacogdoches, Diboll, Huntington, and all of East Texas."
>
  <Breadcrumb items={[{ label: 'Contact', href: '/contact' }]} />
  <PageHero
    title="Get a Free Quote"
    subtitle="Fill out the form below or call us directly. We'll respond within one business day to schedule your free on-site consultation."
    tag="No Obligation — Free Estimates"
    image="/images/general-contractor-lufkin-tx.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">

        <!-- Contact form -->
        <div class="lg:col-span-2">
          <div class="rounded-xl border border-warm-200 bg-white p-8 shadow-card">
            <h2 class="display-sm mb-6 text-charcoal-900">Tell Us About Your Project</h2>
            <form name="contact" action="/thank-you" method="POST" data-netlify="true" class="space-y-5">
              <input type="hidden" name="form-name" value="contact" />
              <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                <div>
                  <label for="name" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-charcoal-500">
                    Full Name <span class="text-brand-red" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    autocomplete="name"
                    placeholder="John Smith"
                    class="w-full rounded-lg border border-warm-300 bg-warm-50 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-300 transition-colors duration-150 focus:border-brand-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/20"
                  />
                </div>
                <div>
                  <label for="phone" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-charcoal-500">
                    Phone Number
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    autocomplete="tel"
                    placeholder="(936) 555-0000"
                    class="w-full rounded-lg border border-warm-300 bg-warm-50 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-300 transition-colors duration-150 focus:border-brand-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/20"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-charcoal-500">
                  Email Address <span class="text-brand-red" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="you@email.com"
                  class="w-full rounded-lg border border-warm-300 bg-warm-50 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-300 transition-colors duration-150 focus:border-brand-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/20"
                />
              </div>

              <div>
                <label for="service" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-charcoal-500">
                  Service Needed
                </label>
                <select
                  id="service"
                  name="service"
                  class="w-full rounded-lg border border-warm-300 bg-warm-50 px-4 py-3 text-sm text-charcoal-800 transition-colors duration-150 focus:border-brand-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/20"
                >
                  <option value="">Select a service...</option>
                  <optgroup label="Remodeling">
                    <option>Kitchen Remodeling</option>
                    <option>Bathroom Remodeling</option>
                    <option>Home Addition</option>
                    <option>Interior Painting</option>
                    <option>Flooring Installation</option>
                    <option>Drywall Installation / Repair</option>
                  </optgroup>
                  <optgroup label="New Construction">
                    <option>Residential / Custom Home</option>
                    <option>Commercial Construction</option>
                    <option>Barndominium</option>
                    <option>Pole Barn</option>
                    <option>Tiny Home</option>
                  </optgroup>
                  <optgroup label="Outdoor Living">
                    <option>Patio / Deck</option>
                    <option>Pergola / Pavilion</option>
                    <option>Fence Installation</option>
                    <option>Driveway / Walkway</option>
                  </optgroup>
                  <optgroup label="Exterior Services">
                    <option>Siding Installation</option>
                    <option>Window / Door Installation</option>
                    <option>Exterior Painting</option>
                    <option>Gutter Installation</option>
                    <option>Insulation Installation</option>
                  </optgroup>
                  <option>Project Planning &amp; Consulting</option>
                  <option>Site Preparation</option>
                  <option>Multiple / Not Sure</option>
                </select>
              </div>

              <div>
                <label for="message" class="mb-1.5 block text-xs font-semibold uppercase tracking-widest text-charcoal-500">
                  Project Details <span class="text-brand-red" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Briefly describe your project — location, scope, timeline, and any questions you have."
                  class="w-full rounded-lg border border-warm-300 bg-warm-50 px-4 py-3 text-sm text-charcoal-800 placeholder-charcoal-300 transition-colors duration-150 focus:border-brand-red focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-red/20 resize-none"
                ></textarea>
              </div>

              <button type="submit" class="btn-primary w-full justify-center py-4">
                Send Message — Get a Free Quote
                <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </button>

              <div class="flex items-center gap-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
                <svg class="h-4 w-4 flex-shrink-0 text-amber-600" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
                <p class="text-xs font-semibold text-amber-800">Financing available — ask us about flexible payment options when we reach out.</p>
              </div>

              <p class="text-xs text-charcoal-400 text-center">
                We respond within 1 business day. Your information is never shared or sold.
              </p>
            </form>
          </div>
        </div>

        <!-- Contact info sidebar -->
        <div class="space-y-6">
          <!-- Direct contact -->
          <div class="rounded-xl border border-warm-200 bg-white p-6 shadow-card">
            <h3 class="display-sm mb-4 text-charcoal-900">Contact Directly</h3>
            <address class="not-italic space-y-4">
              <a
                href="tel:9365555555"
                class="flex items-start gap-3 group"
              >
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-md bg-brand-red-light text-brand-red">
                  <svg class="h-4 w-4" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-charcoal-400">Phone</p>
                  <p class="text-sm font-semibold text-charcoal-800 group-hover:text-brand-red transition-colors duration-150">(936) 555-5555</p>
                </div>
              </a>
              <a
                href="mailto:info@purposeconstructionco.com"
                class="flex items-start gap-3 group"
              >
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-md bg-brand-red-light text-brand-red">
                  <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-charcoal-400">Email</p>
                  <p class="text-sm font-semibold text-charcoal-800 group-hover:text-brand-red transition-colors duration-150 break-all">info@purposeconstructionco.com</p>
                </div>
              </a>
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-md bg-brand-red-light text-brand-red">
                  <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-charcoal-400">Location</p>
                  <p class="text-sm font-semibold text-charcoal-800">Lufkin, Texas 75904</p>
                </div>
              </div>
            </address>
          </div>

          <!-- Hours -->
          <div class="rounded-xl border border-warm-200 bg-white p-6 shadow-card">
            <h3 class="display-sm mb-4 text-charcoal-900">Business Hours</h3>
            <div class="space-y-2 text-sm">
              {[
                { day: 'Monday – Friday', hours: '7:00 AM – 6:00 PM' },
                { day: 'Saturday', hours: '8:00 AM – 2:00 PM' },
                { day: 'Sunday', hours: 'Closed' },
              ].map((row) => (
                <div class="flex items-center justify-between border-b border-warm-200 pb-2 last:border-0 last:pb-0">
                  <span class="text-charcoal-500">{row.day}</span>
                  <span class:list={['font-semibold', row.hours === 'Closed' ? 'text-charcoal-300' : 'text-charcoal-800']}>{row.hours}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="rounded-xl border-2 border-dashed border-warm-300 bg-warm-50 p-8 text-center">
            <svg class="mx-auto mb-3 h-8 w-8 text-charcoal-300" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            <p class="text-xs text-charcoal-400">Map placeholder — embed Google Map here</p>
            <a
              href="https://maps.google.com/?q=Lufkin+Texas+75904"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 inline-block text-xs font-semibold text-brand-red hover:text-brand-red-dark transition-colors duration-150"
            >
              Get Directions →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
