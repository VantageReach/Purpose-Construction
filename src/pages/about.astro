---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<BaseLayout
  title="About Us | Purpose Construction — Lufkin, TX General Contractor"
  description="Learn about Purpose Construction — a Lufkin-based general contractor serving East Texas with insured construction services. Custom homes, remodeling, barndominiums, and more."
>
  <Breadcrumb items={[{ label: 'About', href: '/about' }]} />
  <PageHero
    title="About Purpose Construction"
    subtitle="A Lufkin-based general contractor built on honest work, local knowledge, and a genuine commitment to the East Texas communities we serve."
    tag="Who We Are"
  />

  <!-- Story section -->
  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading
            tag="Our Story"
            title="Built Right Here in East Texas"
          />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>
              Purpose Construction was founded in Lufkin with one straightforward goal: to be the kind of contractor that homeowners and business owners in East Texas can actually trust. No surprises on the invoice, no disappearing crews, no cutting corners when no one is watching.
            </p>
            <p>
              We handle residential and commercial construction projects of every scope — from full custom home builds and barndominiums to kitchen remodels, outdoor living spaces, and exterior upgrades. Lufkin is our home, and the people we serve are our neighbors.
            </p>
            <p>
              As the sister company to <a href="https://www.purpose-roofing.com" target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-red hover:text-brand-red-dark transition-colors duration-150">Purpose Roofing</a>, we share the same ownership, the same values, and the same commitment to serving Angelina County and surrounding communities with integrity.
            </p>
          </div>
        </div>
        <div class="relative">
          <img
            src="https://placehold.co/640x480/2a2520/555?text=Our+Team"
            alt="Purpose Construction team members at a Lufkin, TX job site"
            class="rounded-xl shadow-hero w-full"
            width="640"
            height="480"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute -bottom-4 -left-4 rounded-lg bg-brand-red px-5 py-4 text-white shadow-red">
            <p class="font-display text-2xl font-bold leading-none">10+</p>
            <p class="text-xs font-semibold uppercase tracking-widest text-white/80">Years in East Texas</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading
        tag="How We Work"
        title="What Sets Us Apart"
        align="center"
      />
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: 'Insured & Trusted',
            body: 'We carry full licensing and insurance on every project. You\'re protected, and so is your investment.',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Transparent Pricing',
            body: 'Your proposal includes a written scope of work and itemized pricing. What you sign is what you pay — no bait-and-switch.',
            icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
          },
          {
            title: 'Local Knowledge',
            body: 'We know East Texas — the soil, the humidity, the codes, and the materials that perform long-term in this climate.',
            icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
          },
          {
            title: 'On-Time Crews',
            body: 'We respect your time. Our crews show up when they say they will, and we keep you updated throughout the project.',
            icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
          },
          {
            title: 'Workmanship Warranty',
            body: 'We stand behind our work. Every project comes with a workmanship warranty because that\'s what doing the job right means to us.',
            icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
          },
          {
            title: 'Full-Service Capability',
            body: 'From site prep and framing to finish work, we handle every phase in-house or with trusted subcontractors we\'ve worked with for years.',
            icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
          },
        ].map((item) => (
          <div class="rounded-xl border border-warm-200 bg-warm-50 p-6 shadow-card">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-md bg-brand-red-light text-brand-red">
              <svg class="h-5 w-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
              </svg>
            </div>
            <h3 class="display-sm mb-2 text-charcoal-900">{item.title}</h3>
            <p class="text-sm leading-relaxed text-charcoal-500">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sister company -->
  <section class="section-padding-sm bg-charcoal-900 border-t border-charcoal-800">
    <div class="container-mid px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-between gap-6 text-center sm:flex-row sm:text-left rounded-xl border border-charcoal-700 bg-charcoal-800 p-8">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-charcoal-400 mb-1">Part of the Purpose Family</p>
          <h2 class="display-sm text-white mb-2">Purpose Roofing</h2>
          <p class="text-sm text-charcoal-300 max-w-md">
            Our sister company provides expert roofing services across East Texas. If your project needs a new roof — or if roofing is the only thing you need — visit Purpose Roofing for a separate free estimate.
          </p>
        </div>
        <a
          href="https://www.purpose-roofing.com"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline flex-shrink-0 border-charcoal-600 text-charcoal-200 hover:bg-white hover:text-charcoal-900 hover:border-white"
        >
          Visit Purpose Roofing
          <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Let's Work Together</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">
        Ready to start your project? Get in touch for a free on-site consultation and estimate. No pressure — just honest answers and a clear plan.
      </p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Contact Us Today</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
