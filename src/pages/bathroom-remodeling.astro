---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const faqs = [
  { q: 'How long does a bathroom remodel take in Lufkin?', a: 'A standard bathroom remodel takes 2–4 weeks. A full primary bathroom renovation with tile work, layout changes, and custom features can run 4–6 weeks. We provide a written timeline before any work begins.' },
  { q: 'Can I get a walk-in shower installed in my existing bathroom?', a: 'Yes — this is one of our most common remodel requests. We assess the space, determine if layout changes are needed, handle all tile and waterproofing work, and install the fixtures. Most conversions can be completed without expanding the room.' },
  { q: 'Do you handle all the tile work in-house?', a: 'Yes. Our crews handle demo, waterproofing, tile setting, grouting, and all associated finish work. We don\'t subcontract tile work to unfamiliar parties.' },
  { q: 'What bathroom remodel ROI can I expect?', a: 'Bathroom remodels consistently rank among the highest-return renovation investments. In East Texas, a mid-range bathroom remodel typically returns 60–70% of cost in home value. A luxury primary bath can return more in the right neighborhoods.' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Bathroom Remodeling',
    provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
    areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
    description: 'Custom bathroom remodeling across East Texas. Tile, showers, vanities, flooring, and full bath renovations for East Texas homeowners.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---

<BaseLayout
  title="Bathroom Remodeling East Texas | Purpose Construction"
  description="Custom bathroom remodeling across East Texas by Purpose Construction. Tile showers, vanities, flooring, walk-in showers, and complete bath renovations for East Texas homeowners. Free estimates."
  schema={schema}
>
  <Breadcrumb items={[
    { label: 'Services', href: '/services' },
    { label: 'Remodeling', href: '/remodeling-contractor' },
    { label: 'Bathroom Remodeling', href: '/bathroom-remodeling' },
  ]} />

  <PageHero
    title="Bathroom Remodeling in East Texas"
    subtitle="From walk-in showers and soaking tubs to complete primary bathroom overhauls — Purpose Construction delivers bathroom remodels East Texas homeowners trust."
    tag="Core Service"
    image="/images/bathroom-remodeling-lufkin-tx.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Bathroom Remodeling" title="Transform Your Bathroom" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>A well-done bathroom remodel changes how you start and end every day. Purpose Construction handles everything — layout changes, waterproofing, tile work, vanities, fixtures, and lighting — so you get a finished product that functions well and looks exceptional.</p>
            <p>We serve homeowners across East Texas, Nacogdoches, Diboll, and East Texas with bathroom remodeling that fits their space, their style, and their budget. Every project starts with a free on-site estimate and ends with a final walkthrough you're proud of.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="tel:9365555555" class="btn-outline">Call (936) 555-5555</a>
          </div>
        </div>
        <img
          src="/images/bathroom-remodeling-lufkin-tx.jpg"
          alt="Bathroom remodel by Purpose Construction in East Texas"
          class="rounded-xl shadow-hero"
          width="640"
          height="480"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What We Handle" title="Full-Scope Bathroom Renovations" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {[
          'Demolition & Disposal', 'Tile Shower Installation', 'Walk-In Shower Conversion',
          'Soaking Tub Installation', 'Vanity & Cabinet Install', 'Countertop & Sink',
          'Tile Flooring', 'Electrical & Lighting', 'Plumbing Fixtures',
          'Waterproofing', 'Exhaust Fans', 'Permit Management',
        ].map((item) => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-mid px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Common Questions" title="Bathroom Remodeling FAQs" align="center" />
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-warm-200 bg-warm-50 shadow-card">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 list-none">
              <h3 class="text-sm font-semibold text-charcoal-800 pr-4">{faq.q}</h3>
              <svg class="h-5 w-5 flex-shrink-0 text-charcoal-400 transition-transform duration-200 group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-charcoal-600">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Often Paired With Bathroom Remodeling" />
      <div class="flex flex-wrap gap-3">
        {[
          { label: 'Kitchen Remodeling', href: '/kitchen-remodeling' },
          { label: 'Home Additions', href: '/home-additions' },
          { label: 'Flooring Installation', href: '/flooring-installation' },
          { label: 'All Remodeling Services', href: '/remodeling-contractor' },
        ].map((link) => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">
            {link.label} →
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Start Your Bathroom Remodel</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact us for a free on-site estimate. We serve all of East Texas with no-pressure, honest quotes.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
