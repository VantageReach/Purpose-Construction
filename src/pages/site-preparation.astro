---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Site Preparation',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Site preparation across East Texas — land clearing, grading, drainage, utilities rough-in, and septic coordination to make East Texas properties ready to build on.',
};
---
<BaseLayout
  title="Site Preparation East Texas | Purpose Construction"
  description="Site preparation across East Texas — land clearing, grading, drainage, and utilities rough-in for new construction across East Texas. Purpose Construction gets your property build-ready. Call (936) 555-5555."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Site Preparation', href: '/site-preparation' }]} />
  <PageHero title="Site Preparation in East Texas" subtitle="Land clearing, grading, drainage planning, and utilities rough-in — getting your East Texas property properly prepared before construction begins." tag="General Service" 
    image="/images/site-preparation-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Site Preparation" title="A Well-Prepared Site Makes Everything Easier" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Building anywhere in East Texas starts with site work — and East Texas sites come with their own set of challenges. Dense pine forest cover requires clearing and stump grinding. The clay-heavy soils in Angelina County require careful grading and drainage planning, because water that doesn't drain away from a building site will cause foundation problems, erosion, and access issues for the entire life of the structure. Purpose Construction approaches site preparation with the end in mind — thinking through how the finished site needs to drain, where utility runs need to go, and how to protect the surrounding trees and natural features where possible.</p>
            <p>We handle tree removal and land clearing for new home sites, barndominiums, pole barns, and commercial developments across East Texas and surrounding East Texas communities. Grading is done with finished drainage in mind — not just getting the lot level, but establishing the positive drainage patterns that will protect your foundation for decades. Where a septic system is required, we coordinate with the installer so the site prep and septic field placement are sequenced correctly.</p>
            <p>Driveway access points require proper culvert sizing and installation to satisfy county road requirements and keep your property entrance from washing out. We handle culvert installation as part of site preparation so you're not dealing with access problems before construction can even begin.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/services" class="btn-outline">All Services</a>
          </div>
        </div>
        <img src="/images/site-preparation-east-texas.jpg" alt="Site preparation across East Texas by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Site Preparation Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Land Clearing', 'Tree Removal', 'Grading & Leveling', 'Erosion Control', 'Drainage Planning', 'Utilities Rough-In', 'Driveway Access', 'Septic System Coordination'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="What Comes After Site Prep" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Project Planning', href: '/project-planning-consulting' }, { label: 'New Construction', href: '/new-construction' }, { label: 'Barndominium Construction', href: '/barndominium-construction' }, { label: 'All Services', href: '/services' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Ready to Get Your Land Build-Ready?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free site preparation estimate. We clear, grade, and prepare properties for construction across East Texas and East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
