---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Card from '../components/Card.astro';

const categories = [
  {
    heading: 'Remodeling',
    href: '/remodeling-contractor',
    description: 'Full interior remodeling services — kitchens, bathrooms, additions, painting, flooring, and drywall.',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    services: [
      { label: 'Kitchen Remodeling', href: '/kitchen-remodeling', core: true },
      { label: 'Bathroom Remodeling', href: '/bathroom-remodeling', core: true },
      { label: 'Home Additions', href: '/home-additions', core: true },
      { label: 'Interior Painting', href: '/interior-painting', core: false },
      { label: 'Flooring Installation', href: '/flooring-installation', core: false },
      { label: 'Drywall Installation', href: '/drywall-installation', core: false },
      { label: 'Drywall Repair', href: '/drywall-repair', core: false },
    ],
  },
  {
    heading: 'New Construction',
    href: '/new-construction',
    description: 'Custom homes, commercial structures, barndominiums, pole barns, and tiny homes built from the ground up.',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    services: [
      { label: 'Residential Construction', href: '/residential-construction', core: false },
      { label: 'Commercial Construction', href: '/commercial-construction', core: false },
      { label: 'Barndominium Construction', href: '/barndominium-construction', core: true },
      { label: 'Pole Barn Construction', href: '/pole-barn-construction', core: false },
      { label: 'Tiny Home Construction', href: '/tiny-home-construction', core: false },
    ],
  },
  {
    heading: 'Outdoor Living',
    href: '/outdoor-living',
    description: 'Patios, decks, pergolas, pavilions, fences, driveways, and walkways for East Texas outdoor spaces.',
    icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
    services: [
      { label: 'Patio Construction', href: '/patio-construction', core: false },
      { label: 'Deck Construction', href: '/deck-construction', core: false },
      { label: 'Pergola Construction', href: '/pergola-construction', core: false },
      { label: 'Pavilion Construction', href: '/pavilion-construction', core: false },
      { label: 'Fence Installation', href: '/fence-installation', core: false },
      { label: 'Driveway Installation', href: '/driveway-installation', core: false },
      { label: 'Walkway Installation', href: '/walkway-installation', core: false },
    ],
  },
  {
    heading: 'Exterior Services',
    href: '/exterior-services',
    description: 'Siding, windows, doors, exterior painting, gutters, and insulation to protect and upgrade your home\'s exterior.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    services: [
      { label: 'Siding Installation', href: '/siding-installation', core: false },
      { label: 'Window Installation', href: '/window-installation', core: false },
      { label: 'Door Installation', href: '/door-installation', core: false },
      { label: 'Exterior Painting', href: '/exterior-painting', core: false },
      { label: 'Gutter Installation', href: '/gutter-installation', core: false },
      { label: 'Insulation Installation', href: '/insulation-installation', core: false },
    ],
  },
];

const generalServices = [
  { label: 'Project Planning & Consulting', href: '/project-planning-consulting' },
  { label: 'Site Preparation', href: '/site-preparation' },
];
---

<BaseLayout
  title="Construction Services | Purpose Construction — Lufkin, TX"
  description="Browse all construction services from Purpose Construction in Lufkin, TX. Remodeling, new construction, outdoor living, and exterior services for East Texas homeowners."
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }]} />
  <PageHero
    title="Our Services"
    subtitle="From full custom builds to targeted repairs — Purpose Construction handles projects of every scope across East Texas."
    tag="Lufkin, TX General Contractor"
    image="/images/construction-company-lufkin-tx.jpg"
  />

  <!-- Category grids -->
  {categories.map((cat) => (
    <section class="section-padding border-b border-warm-200 bg-warm-50 last:border-b-0">
      <div class="container-wide px-4 sm:px-6 lg:px-8">
        <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <SectionHeading
            tag="Service Category"
            title={cat.heading}
            subtitle={cat.description}
          />
          <a href={cat.href} class="btn-outline flex-shrink-0 self-start sm:self-auto">
            View Category
          </a>
        </div>
        <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {cat.services.map((svc) => (
            <li>
              <a
                href={svc.href}
                class="group flex items-center justify-between rounded-lg border border-warm-200 bg-white px-5 py-4 shadow-card transition-all duration-200 hover:-translate-y-px hover:border-brand-red-mid hover:shadow-card-hover"
              >
                <span class="text-sm font-semibold text-charcoal-700 group-hover:text-charcoal-900 transition-colors duration-150">
                  {svc.label}
                  {svc.core && (
                    <span class="ml-2 inline-block rounded-sm bg-brand-red-light px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-widest text-brand-red">
                      Featured
                    </span>
                  )}
                </span>
                <svg class="h-4 w-4 flex-shrink-0 text-charcoal-300 group-hover:text-brand-red transition-colors duration-150" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <!-- General services -->
  <section class="section-padding-sm bg-white border-b border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading
        tag="Also Available"
        title="General Services"
        subtitle="Supporting services that underpin every successful construction project."
      />
      <ul class="flex flex-wrap gap-3">
        {generalServices.map((svc) => (
          <li>
            <a
              href={svc.href}
              class="group flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card transition-all duration-200 hover:border-brand-red-mid hover:text-charcoal-900"
            >
              {svc.label}
              <svg class="h-4 w-4 text-charcoal-300 group-hover:text-brand-red transition-colors duration-150" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Not Sure Where to Start?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">
        Call us or fill out the form and we'll walk through your project together — free of charge, no commitment required.
      </p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
