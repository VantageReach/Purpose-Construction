---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Pole Barn Construction',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Pole barn construction across East Texas — post-frame buildings with metal roofing, metal siding, concrete slabs, roll-up doors, and optional electrical for East Texas properties.',
};
---
<BaseLayout
  title="Pole Barn Construction East Texas | Purpose Construction"
  description="Pole barn construction across East Texas — post-frame buildings with metal roof, siding, concrete slab, and roll-up doors. Purpose Construction builds across East Texas. Call (936) 555-5555."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'New Construction', href: '/new-construction' }, { label: 'Pole Barn Construction', href: '/pole-barn-construction' }]} />
  <PageHero title="Pole Barn Construction in East Texas" subtitle="Post-frame pole barns built for East Texas — farm storage, equipment shops, and working buildings that handle the weather and hold up for decades." tag="New Construction Service" 
    image="/images/pole-barn-construction-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Pole Barn Construction" title="Durable, Efficient Buildings for East Texas Land" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Pole barns are one of the most practical and cost-effective building types for East Texas landowners. Whether you need a farm storage building, an equipment shop, a hay barn, or a multi-purpose working structure, post-frame construction delivers a strong, long-lasting building at a fraction of the cost of traditional construction. Purpose Construction builds pole barns across East Texas and Angelina County for agricultural, commercial, and residential uses.</p>
            <p>We handle every phase — from site grading and concrete slab to post-frame erection, metal roofing, and metal siding. East Texas gets heavy rainfall and high winds during storm season, so we build with structural integrity in mind, using properly set posts and quality fasteners that won't back out over time.</p>
            <p>We can add personnel doors, roll-up doors, windows, and electrical to make your pole barn as functional as your project demands — from a simple open-air equipment shelter to a fully finished shop.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/new-construction" class="btn-outline">All New Construction</a>
          </div>
        </div>
        <img src="/images/pole-barn-construction-east-texas.jpg" alt="Pole barn construction across East Texas by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Pole Barn Construction Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Post-Frame Design', 'Concrete Slab', 'Metal Roofing', 'Metal Siding', 'Roll-Up Doors', 'Personnel Doors', 'Windows', 'Electrical', 'Lean-To Additions'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Related Construction Services" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Barndominium Construction', href: '/barndominium-construction' }, { label: 'Site Preparation', href: '/site-preparation' }, { label: 'Outdoor Living', href: '/outdoor-living' }, { label: 'All New Construction', href: '/new-construction' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Ready to Build a Pole Barn?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free pole barn estimate. We build across East Texas and East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
