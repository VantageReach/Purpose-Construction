---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const faqs = [
  { q: 'What is a barndominium?', a: 'A barndominium is a metal building — traditionally styled after a barn — with a fully finished residential interior. They are popular in rural East Texas because they offer large open-concept floor plans, durability, low maintenance, and cost efficiency compared to traditional stick-built homes. Many also include a workshop or garage bay within the same structure.' },
  { q: 'How much does a barndominium cost in East Texas?', a: 'Barndominium construction costs in East Texas typically range from $80–$150 per square foot for the shell and basic finishes, depending on the level of interior finish-out. A 2,000 sq ft barndominium fully finished can range from $160,000–$300,000 depending on customization. Purpose Construction provides free, itemized estimates before any commitment.' },
  { q: 'Do I need a special foundation for a barndominium?', a: 'Most barndominiums in East Texas are built on a monolithic concrete slab. The foundation type depends on your soil conditions — sandy soils common in some areas of Angelina County may require additional engineering. We assess your site during the consultation phase and specify the appropriate foundation system.' },
  { q: 'Can a barndominium be used as a primary residence?', a: 'Absolutely. Modern barndominiums include full residential insulation, HVAC, plumbing, electrical, and interior finishes — exactly like a traditional home. Many of our barndominium customers live in them full-time and find them more comfortable and efficient than their previous homes.' },
  { q: 'How long does it take to build a barndominium?', a: 'From permit approval to move-in, a barndominium typically takes 4–8 months depending on size, site conditions, and finish level. The metal shell goes up quickly — interior finish-out is where the timeline sits. We\'ll give you a detailed schedule in your written proposal.' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Barndominium Construction',
    provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
    areaServed: [
      { '@type': 'City', name: 'Lufkin' },
      { '@type': 'AdministrativeArea', name: 'Angelina County' },
      { '@type': 'AdministrativeArea', name: 'East Texas' },
    ],
    description: 'Custom barndominium construction across East Texas and East Texas. Purpose Construction builds fully finished barndominiums on your land — metal shell, custom interiors, porches, and all site work.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---

<BaseLayout
  title="Barndominium Construction East Texas | Purpose Construction"
  description="Custom barndominium construction across East Texas and East Texas. Purpose Construction builds fully finished barndominiums on your land. Insured general contractor. Free estimates — call (936) 555-5555."
  schema={schema}
>
  <Breadcrumb items={[
    { label: 'Services', href: '/services' },
    { label: 'New Construction', href: '/new-construction' },
    { label: 'Barndominium Construction', href: '/barndominium-construction' },
  ]} />

  <PageHero
    title="Barndominium Construction in East Texas"
    subtitle="Purpose Construction builds custom barndominiums across East Texas — metal shell to full interior finish-out, on your land, built to your plans."
    tag="East Texas Specialty"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Barndominium Builder" title="Custom Barndominiums Built for East Texas Living" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Barndominiums are one of the most popular builds in rural East Texas — and for good reason. You get the durability and low maintenance of a metal structure with the comfort and customization of a modern home. Large open floor plans, high ceilings, built-in workshop bays, wraparound porches — the barndominium delivers what East Texas landowners want.</p>
            <p>Purpose Construction handles the complete build: site preparation, slab, metal shell erection, windows and doors, insulation, framing, drywall, electrical, plumbing, HVAC, and all interior finishes. We also coordinate any required septic, well, and utility work.</p>
            <p>We've built barndominiums across Angelina County, Nacogdoches County, Trinity County, and surrounding areas. We know the local codes, the soil conditions, and what it takes to build a barndominium that stands for generations.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="tel:9365555555" class="btn-outline">Call (936) 555-5555</a>
          </div>
        </div>
        <img
          src="https://placehold.co/640x480/2a2520/555?text=Barndominium"
          alt="Custom barndominium built by Purpose Construction in East Texas"
          class="rounded-xl shadow-hero"
          width="640"
          height="480"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Full-Scope Build" title="Everything Included" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {[
          'Site Clearing & Grading', 'Slab Foundation', 'Metal Shell & Roof',
          'Doors & Windows', 'Spray Foam Insulation', 'Framing & Drywall',
          'Electrical', 'Plumbing', 'HVAC',
          'Interior Finishes', 'Exterior Porches', 'Septic & Well Coordination',
        ].map((item) => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why barndo -->
  <section class="section-padding bg-warm-100 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Why Barndominium?" title="Built for East Texas Land" align="center" />
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Cost-Efficient', body: 'Metal construction often costs less per square foot than traditional stick-built homes of comparable size.' },
          { title: 'Low Maintenance', body: 'Metal exteriors resist rot, pests, and weather — requiring far less ongoing maintenance than wood-framed homes.' },
          { title: 'Fully Customizable', body: 'Open floor plans, shop bays, lofts, wraparound porches — design the layout that fits how you actually live.' },
          { title: 'Fast to Build', body: 'Metal shell goes up in days. With no load-bearing interior walls to worry about, interior finish-out moves quickly too.' },
        ].map((item) => (
          <div class="rounded-xl border border-warm-200 bg-white p-6 shadow-card">
            <h3 class="display-sm mb-2 text-charcoal-900">{item.title}</h3>
            <p class="text-sm leading-relaxed text-charcoal-500">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-mid px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Common Questions" title="Barndominium FAQs" align="center" />
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-warm-200 bg-warm-50 shadow-card">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 list-none">
              <h3 class="text-sm font-semibold text-charcoal-800 pr-4">{faq.q}</h3>
              <svg class="h-5 w-5 flex-shrink-0 text-charcoal-400 transition-transform duration-200 group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-charcoal-600">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Often Combined With Barndominium Builds" />
      <div class="flex flex-wrap gap-3">
        {[
          { label: 'Pole Barn Construction', href: '/pole-barn-construction' },
          { label: 'Residential Construction', href: '/residential-construction' },
          { label: 'Outdoor Living', href: '/outdoor-living' },
          { label: 'Site Preparation', href: '/site-preparation' },
          { label: 'All New Construction', href: '/new-construction' },
        ].map((link) => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">
            {link.label} →
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Build Your Barndominium</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Ready to put a plan together? Contact Purpose Construction for a free consultation and estimate. We serve all of East Texas — on your land, built your way.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
