---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Drywall Installation',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'City', name: 'Lufkin', containedIn: { '@type': 'State', name: 'Texas' } },
  description: 'Professional drywall installation in Lufkin, TX — hang, tape, mud, sand, and texture for new construction, additions, and remodels throughout East Texas.',
};
---
<BaseLayout
  title="Drywall Installation Lufkin TX | Purpose Construction"
  description="Drywall installation in Lufkin, TX — hang, tape, mud, texture, and paint-ready finish. Purpose Construction handles new construction and remodels. Call (936) 555-5555."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Remodeling', href: '/remodeling-contractor-lufkin-tx' }, { label: 'Drywall Installation', href: '/drywall-installation-lufkin-tx' }]} />
  <PageHero title="Drywall Installation in Lufkin, TX" subtitle="Complete drywall installation from hanging and taping to mud, sand, texture, and a paint-ready finish — for new builds, additions, and remodels." tag="Remodeling Service" />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Drywall Installation" title="Walls That Are Ready for the Next Trade" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Drywall installation is one of those trades where the quality of the work determines what every other finish looks like. Badly taped seams and uneven mud show through paint. Purpose Construction brings the same discipline to drywall that we bring to every phase — proper board selection, clean hanging, tight taping, and finish work that holds up without visible imperfections.</p>
            <p>East Texas humidity is hard on drywall if the wrong product gets used in the wrong place. We specify moisture-resistant board in bathrooms, laundry rooms, and anywhere else that sees humidity, so the walls stay solid over time. For garages and mechanical spaces, we use fire-rated drywall where code requires it.</p>
            <p>Whether it's a room addition, a full new-construction shell, or interior remodel work in Lufkin, we deliver walls that are flat, clean, and ready for paint — on schedule.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/remodeling-contractor-lufkin-tx" class="btn-outline">All Remodeling Services</a>
          </div>
        </div>
        <img src="https://placehold.co/640x480/2a2520/555?text=Drywall+Installation" alt="Drywall installation in Lufkin, TX by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Drywall Installation Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Hang & Tape', 'Mud & Sand', 'Texture Application', 'Corner Bead', 'Moisture-Resistant Board', 'Fire-Rated Drywall', 'Ceiling Drywall', 'Arch & Curved Walls', 'Cleanup'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Often Paired With Drywall Installation" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Drywall Repair', href: '/drywall-repair-lufkin-tx' }, { label: 'Interior Painting', href: '/interior-painting-lufkin-tx' }, { label: 'Home Additions', href: '/home-additions-lufkin-tx' }, { label: 'All Remodeling', href: '/remodeling-contractor-lufkin-tx' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Need Drywall Work Done Right?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free drywall installation estimate in Lufkin and across East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
