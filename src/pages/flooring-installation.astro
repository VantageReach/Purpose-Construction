---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Flooring Installation',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://www.purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Professional flooring installation across East Texas — hardwood, LVP, tile, laminate, and carpet installed with proper subfloor prep and moisture protection for East Texas homes.',
};
---
<BaseLayout
  title="Flooring Installation East Texas | Purpose Construction"
  description="Flooring installation across East Texas — hardwood, LVP, tile, laminate, and carpet. Purpose Construction handles full demo, subfloor prep, and install. Call (936) 255-2235."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Remodeling', href: '/remodeling-contractor' }, { label: 'Flooring Installation', href: '/flooring-installation' }]} />
  <PageHero title="Flooring Installation in East Texas" subtitle="From hardwood and LVP to tile and carpet — complete flooring installation with proper subfloor prep and moisture protection for East Texas homes." tag="Remodeling Service" 
    image="/images/flooring-installation-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Flooring Installation" title="A Solid Foundation Under Every Floor" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>East Texas homes face unique flooring challenges — the region's high humidity, clay soils, and seasonal moisture swings can cause floors to buckle, cup, or crack when they aren't installed correctly. Purpose Construction accounts for these conditions on every job, starting with a proper subfloor assessment, leveling, and moisture barrier before the first plank ever goes down.</p>
            <p>We install hardwood, luxury vinyl plank, tile, laminate, and carpet for homeowners across East Texas and Angelina County. Whether you're replacing worn carpet in a single bedroom or installing new floors throughout a full home remodel, we handle complete demo, disposal, and installation from start to finish.</p>
            <p>Every flooring project is finished with proper transitions, trim, and detail work — so the result looks finished and professional, not just functional.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/remodeling-contractor" class="btn-outline">All Remodeling Services</a>
          </div>
        </div>
        <img src="/images/flooring-installation-east-texas.jpg" alt="Flooring installation across East Texas by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Flooring Services We Provide" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Hardwood Flooring', 'LVP / Luxury Vinyl', 'Tile Flooring', 'Laminate', 'Carpet', 'Subfloor Repair', 'Transition Strips', 'Floor Leveling', 'Moisture Barrier', 'Demo & Disposal'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Often Paired With Flooring Installation" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Interior Painting', href: '/interior-painting' }, { label: 'Kitchen Remodeling', href: '/kitchen-remodeling' }, { label: 'Bathroom Remodeling', href: '/bathroom-remodeling' }, { label: 'All Remodeling', href: '/remodeling-contractor' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Ready for New Floors?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free flooring estimate. We serve Lufkin and all of East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9362552235" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 255-2235</a>
      </div>
    </div>
  </section>
</BaseLayout>
