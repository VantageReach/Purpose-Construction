---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Outdoor Living Contractor',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Outdoor living construction services across East Texas — patios, decks, pergolas, pavilions, fences, driveways, and walkways.',
};

const services = [
  { title: 'Patio Construction', body: 'Poured concrete, stamped concrete, pavers, and flagstone patios designed for East Texas outdoor entertaining.', href: '/patio-construction' },
  { title: 'Deck Construction', body: 'Pressure-treated, composite, and hardwood decks that stand up to East Texas heat and humidity.', href: '/deck-construction' },
  { title: 'Pergola Construction', body: 'Custom pergolas for shade and style — freestanding or attached to your home, any size.', href: '/pergola-construction' },
  { title: 'Pavilion Construction', body: 'Fully covered pavilions with roofing, lighting options, and optional screens for year-round outdoor living.', href: '/pavilion-construction' },
  { title: 'Fence Installation', body: 'Wood, vinyl, chain link, and ornamental iron fencing for privacy, security, and curb appeal.', href: '/fence-installation' },
  { title: 'Driveway Installation', body: 'Concrete and asphalt driveways installed and finished with proper drainage for East Texas soil conditions.', href: '/driveway-installation' },
  { title: 'Walkway Installation', body: 'Poured concrete, paver, and flagstone walkways connecting your home, garage, and outdoor spaces.', href: '/walkway-installation' },
];
---

<BaseLayout
  title="Outdoor Living Contractor East Texas | Purpose Construction"
  description="Purpose Construction builds outdoor living spaces across East Texas — patios, decks, pergolas, pavilions, fences, driveways, and walkways across East Texas. Free estimates."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Outdoor Living', href: '/outdoor-living' }]} />
  <PageHero
    title="Outdoor Living Contractor in East Texas"
    subtitle="From covered patios to custom pergolas to full outdoor entertainment spaces — Purpose Construction builds the outdoor living East Texas deserves."
    tag="Outdoor Living Services"
    image="/images/outdoor-living-east-texas.jpg"
  />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading
        tag="Outdoor Services"
        title="Your Backyard, Built Right"
        subtitle="East Texas has the land and the weather for serious outdoor living. We build spaces that handle heat, humidity, and heavy use — year after year."
      />
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((svc) => (
          <a
            href={svc.href}
            class="group relative rounded-xl border border-warm-200 bg-white p-6 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-red-mid"
          >
            <h2 class="display-sm mb-2 text-charcoal-900">{svc.title}</h2>
            <p class="text-sm leading-relaxed text-charcoal-500">{svc.body}</p>
            <span class="service-link mt-4 inline-flex">
              Learn more
              <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Built for East Texas" title="Outdoor Spaces That Last" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>East Texas summers are long and hot. Pine roots are aggressive. Humidity causes untreated wood to rot in just a few seasons. Our outdoor construction uses materials and methods proven in this specific climate.</p>
            <p>Whether you're adding a patio to your existing home, building a complete backyard retreat, or installing a durable new driveway — every project is engineered to perform and designed to impress.</p>
          </div>
          <div class="mt-6">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
          </div>
        </div>
        <img
          src="/images/outdoor-living-east-texas.jpg"
          alt="Outdoor living space built by Purpose Construction in East Texas"
          class="rounded-xl shadow-hero"
          width="640"
          height="480"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-100 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Also From Purpose Construction" title="More Services" />
      <div class="flex flex-wrap gap-3">
        {[
          { label: 'Remodeling', href: '/remodeling-contractor' },
          { label: 'New Construction', href: '/new-construction' },
          { label: 'Exterior Services', href: '/exterior-services' },
        ].map((link) => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">
            {link.label} →
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Design Your Outdoor Space</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Tell us about your property and vision. We'll come out, measure up, and put together a free estimate with no pressure and no obligation.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
