---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Remodeling Contractor',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Full interior remodeling services for homes across East Texas including kitchen remodels, bathroom remodels, home additions, flooring, painting, and drywall.',
};

const services = [
  { title: 'Kitchen Remodeling', body: 'Full kitchen renovations — layouts, cabinetry, countertops, flooring, lighting, and custom finishes.', href: '/kitchen-remodeling', core: true },
  { title: 'Bathroom Remodeling', body: 'Complete bathroom overhauls — tile, fixtures, vanities, showers, soaking tubs, and flooring.', href: '/bathroom-remodeling', core: true },
  { title: 'Home Additions', body: 'Expand your living space with room additions, sunrooms, bonus rooms, or full second-story additions.', href: '/home-additions', core: true },
  { title: 'Interior Painting', body: 'Professional interior painting with proper prep, premium paints, and clean finishes from wall to trim.', href: '/interior-painting', core: false },
  { title: 'Flooring Installation', body: 'Hardwood, LVP, tile, laminate, and carpet installation for every room in your home.', href: '/flooring-installation', core: false },
  { title: 'Drywall Installation', body: 'New drywall installation for additions, renovations, and new construction throughout East Texas.', href: '/drywall-installation', core: false },
  { title: 'Drywall Repair', body: 'Patch and repair damaged drywall — holes, water damage, cracks, and texture matching.', href: '/drywall-repair', core: false },
];
---

<BaseLayout
  title="Remodeling Contractor East Texas | Purpose Construction"
  description="Purpose Construction is Lufkin's trusted remodeling contractor. Kitchen remodels, bathroom remodels, home additions, flooring, drywall, and interior painting across East Texas. Free estimates."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Remodeling', href: '/remodeling-contractor' }]} />
  <PageHero
    title="Remodeling Contractor in East Texas"
    subtitle="Transform your home with Purpose Construction. We handle full interior remodeling projects across East Texas — on time, on budget, and built to last."
    tag="Remodeling Services"
  />

  <!-- Services grid -->
  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading
        tag="What We Remodel"
        title="Interior Remodeling Services"
        subtitle="From kitchens and bathrooms to full home additions — every project is scoped clearly, priced honestly, and finished with craftsmanship."
      />
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((svc) => (
          <a
            href={svc.href}
            class="group relative rounded-xl border border-warm-200 bg-white p-6 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-red-mid"
          >
            {svc.core && <span class="tag mb-3 inline-block text-[10px]">Featured</span>}
            <h2 class="display-sm mb-2 text-charcoal-900">{svc.title}</h2>
            <p class="text-sm leading-relaxed text-charcoal-500">{svc.body}</p>
            <span class="service-link mt-4 inline-flex">
              Learn more
              <svg class="h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why remodel with us -->
  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading
            tag="Why Purpose Construction"
            title="Remodeling Done Right — Not Just Done Fast"
          />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>East Texas homes face specific challenges — high humidity, aging wood, and the wear that comes from decades of use. Our remodeling teams are trained for those conditions and select materials that perform in this climate long-term.</p>
            <p>Every remodeling project begins with a detailed written proposal. You know exactly what's included, what's excluded, and what the timeline looks like before we ever break ground.</p>
            <p>We're a insured general contractor, and we stand behind our work with a workmanship warranty. When we're done, we want you calling your neighbors to come see it — not calling us to come back and fix something.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
          </div>
        </div>
        <img
          src="https://placehold.co/640x480/2a2520/555?text=Remodeling"
          alt="Remodeling project by Purpose Construction in East Texas"
          class="rounded-xl shadow-hero"
          width="640"
          height="480"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- Local issues callout -->
  <section class="section-padding-sm bg-warm-100 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="East Texas Expertise" title="We Know Local Homes" align="center" />
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Humidity-Resistant Materials', body: 'We specify materials that resist East Texas moisture — preventing rot, mold, and warping from day one.' },
          { title: 'Older Home Specialists', body: 'Lufkin\'s aging housing stock needs careful attention. We assess structural integrity before any remodel begins.' },
          { title: 'Storm-Ready Finishes', body: 'From impact-resistant windows to proper flashing, we build remodels that hold up through East Texas storm seasons.' },
          { title: 'Local Code Compliance', body: 'We pull all required permits and ensure every project meets Angelina County and City of Lufkin building codes.' },
        ].map((item) => (
          <div class="rounded-lg border border-warm-200 bg-white p-5 shadow-card">
            <h3 class="display-sm mb-2 text-charcoal-900 text-xl">{item.title}</h3>
            <p class="text-sm leading-relaxed text-charcoal-500">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="section-padding-sm bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Also From Purpose Construction" title="More Services" />
      <div class="flex flex-wrap gap-3">
        {[
          { label: 'New Construction', href: '/new-construction' },
          { label: 'Outdoor Living', href: '/outdoor-living' },
          { label: 'Exterior Services', href: '/exterior-services' },
        ].map((link) => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-warm-50 px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">
            {link.label} →
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Ready to Remodel?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction for a free on-site estimate. We serve Lufkin, Nacogdoches, Diboll, Huntington, and all of East Texas.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
