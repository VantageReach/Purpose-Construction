---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionHeading from '../components/SectionHeading.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Commercial Construction',
  provider: { '@type': 'GeneralContractor', name: 'Purpose Construction', url: 'https://purposeconstructionco.com' },
  areaServed: { '@type': 'State', name: 'Texas', containedIn: { '@type': 'Country', name: 'United States' } },
  description: 'Commercial construction across East Texas — shells, tenant buildouts, warehouses, office build-outs, and retail spaces for East Texas businesses.',
};
---
<BaseLayout
  title="Commercial Construction East Texas | Purpose Construction"
  description="Commercial construction across East Texas — shells, tenant buildouts, office spaces, warehouses, and retail. Purpose Construction delivers on time and on budget. Call (936) 555-5555."
  schema={schema}
>
  <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'New Construction', href: '/new-construction' }, { label: 'Commercial Construction', href: '/commercial-construction' }]} />
  <PageHero title="Commercial Construction in East Texas" subtitle="Ground-up commercial builds and tenant buildouts for East Texas businesses — from warehouses and metal buildings to office and retail spaces." tag="New Construction Service" />

  <section class="section-padding bg-warm-50">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <SectionHeading tag="Commercial Construction" title="Built for Business, Delivered on Schedule" />
          <div class="space-y-4 text-base leading-relaxed text-charcoal-600">
            <p>Lufkin's commercial sector continues to grow, and Purpose Construction is positioned to serve local businesses and investors who need a reliable general contractor to manage projects from permitting through ribbon cutting. We handle commercial shells, tenant buildouts, and specialty commercial structures across Angelina County with the same accountability we bring to residential work.</p>
            <p>We understand that commercial projects have hard deadlines — lease commencement dates, investor milestones, and business timelines that don't flex. Purpose Construction builds detailed schedules and manages subcontractors to hit them. Whether you're building a warehouse, outfitting a retail space, or constructing an office building, we track every phase and communicate proactively.</p>
            <p>From metal building erection and tilt-up concrete to full interior buildouts with electrical, plumbing, HVAC, and finishes — we manage the scope so you can focus on your business.</p>
          </div>
          <div class="mt-6 flex gap-4">
            <a href="/contact" class="btn-primary">Get a Free Estimate</a>
            <a href="/new-construction" class="btn-outline">All New Construction</a>
          </div>
        </div>
        <img src="https://placehold.co/640x480/2a2520/555?text=Commercial+Construction" alt="Commercial construction across East Texas by Purpose Construction" class="rounded-xl shadow-hero" width="640" height="480" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="What's Included" title="Commercial Construction Services" align="center" />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {['Commercial Shells', 'Tenant Buildouts', 'Warehouses', 'Office Build-Outs', 'Retail Spaces', 'Metal Buildings', 'Concrete Tilt-Up', 'Site Work', 'Permit Management'].map(item => (
          <div class="flex items-center gap-2 rounded-lg border border-warm-200 bg-warm-50 px-4 py-3 text-sm font-semibold text-charcoal-700">
            <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-red" aria-hidden="true"></span>{item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding-sm bg-warm-50 border-t border-warm-200">
    <div class="container-wide px-4 sm:px-6 lg:px-8">
      <SectionHeading tag="Related Services" title="Related New Construction Services" />
      <div class="flex flex-wrap gap-3">
        {[{ label: 'Residential Construction', href: '/residential-construction' }, { label: 'Site Preparation', href: '/site-preparation' }, { label: 'All New Construction', href: '/new-construction' }].map(link => (
          <a href={link.href} class="rounded-lg border border-warm-200 bg-white px-5 py-3 text-sm font-semibold text-charcoal-700 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-200">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-red">
    <div class="container-mid px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="display-md text-white mb-4">Planning a Commercial Project?</h2>
      <p class="mx-auto mb-8 max-w-xl text-base text-white/80">Contact Purpose Construction to discuss your commercial build across East Texas. Free estimates — no obligation.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-ghost px-8 py-4">Get a Free Quote</a>
        <a href="tel:9365555555" class="text-sm font-semibold text-white/70 hover:text-white transition-colors duration-150">(936) 555-5555</a>
      </div>
    </div>
  </section>
</BaseLayout>
