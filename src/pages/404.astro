---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Purpose Construction"
  description="The page you're looking for doesn't exist or has been moved."
  robots="noindex, nofollow"
>
  <section class="section-padding bg-warm-50 flex-1 flex items-center justify-center min-h-[70vh]">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-display text-[120px] font-bold leading-none text-warm-200 select-none" aria-hidden="true">404</p>
      <h1 class="display-md text-charcoal-900 -mt-4 mb-4">Page Not Found</h1>
      <p class="text-base leading-relaxed text-charcoal-500 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved. Let us help you find what you need.
      </p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center mb-12">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/contact" class="btn-outline">Contact Us</a>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          { label: 'Services', href: '/services' },
          { label: 'Remodeling', href: '/remodeling-contractor' },
          { label: 'New Construction', href: '/new-construction' },
          { label: 'Outdoor Living', href: '/outdoor-living' },
          { label: 'About', href: '/about' },
        ].map((link) => (
          <a
            href={link.href}
            class="rounded-md border border-warm-200 bg-white px-4 py-2 text-sm font-semibold text-charcoal-600 shadow-card hover:border-brand-red-mid hover:text-charcoal-900 transition-all duration-150"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
